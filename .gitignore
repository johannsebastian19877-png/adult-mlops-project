# Git ignore patterns
# =============================================================================
# Este archivo define qué archivos/directorios NO se suben a Git
# Los datos, modelos y artifacts grandes se versionan con DVC, no con Git
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Jupyter Notebook
.ipynb_checkpoints

# MLOps artifacts (large files tracked by DVC)
# Datos grandes - usar DVC
data/raw/*.parquet
data/raw/*.csv
data/processed/*.parquet
data/interim/

# Artifacts pequeños - permitir en Git para trazabilidad
# artifacts/*.joblib        # Permitidos (transformadores)
# artifacts/*.json          # Permitidos (métricas)
# artifacts/*.html          # Permitidos (reportes)
# artifacts/*.png           # Permitidos (visualizaciones)

# Solo ignorar artifacts muy grandes
artifacts/*.pkl
models/*.pkl
models/*.joblib
models/*.onnx

# MLflow
mlruns/
mlflow_runs/

# DVC
.dvc/cache/
.dvc/tmp/

# Logs
*.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints

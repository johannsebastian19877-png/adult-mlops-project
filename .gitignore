# Git ignore patterns

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Jupyter Notebook
.ipynb_checkpoints

# MLOps artifacts (large files tracked by DVC)
data/raw/*.parquet
data/raw/*.csv
data/processed/*.parquet
data/processed/*.json
data/interim/
artifacts/*.joblib
artifacts/*.pkl
artifacts/*.json
artifacts/*.html
artifacts/*.png
models/*.pkl
models/*.joblib
models/*.onnx

# MLflow
mlruns/
mlflow_runs/

# DVC
.dvc/cache/
.dvc/tmp/

# Logs
*.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints
